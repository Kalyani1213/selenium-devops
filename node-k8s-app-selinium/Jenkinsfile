pipeline {
    agent any

    environment {
        // Ensures Jenkins can find Node, Docker, and Minikube binaries
        PATH = "/usr/bin:/usr/local/bin:${env.PATH}"
        // Points to the Minikube configuration you authorized in the terminal
        MINIKUBE_HOME = "/home/user"
        KUBECONFIG = "/home/user/.kube/config"
    }

    stages {
        stage('Install') {
            steps {
                dir('node-k8s-app-selinium') {
                    sh 'npm install'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('node-k8s-app-selinium') {
                    // Runs Selenium in headless mode (configured in selenium.test.js)
                    sh 'npm test || true'
                }
            }
        }

        stage('Build & Push') {
            steps {
                dir('node-k8s-app-selinium') {
                    sh 'docker build -t kalyani46/my-k8s-app:latest .'
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', 
                                     passwordVariable: 'DOCKER_PASSWORD', 
                                     usernameVariable: 'DOCKER_USERNAME')]) {
                        sh 'echo "${DOCKER_PASSWORD}" | docker login -u "${DOCKER_USERNAME}" --password-stdin'
                        sh 'docker push kalyani46/my-k8s-app:latest'
                    }
                }
            }
        }

        stage('Deploy to K8s') {
            steps {
                dir('node-k8s-app-selinium') {
                    sh '''
                    # Apply changes to the cluster
                    minikube kubectl -- apply -f k8s/deployment.yaml
                    minikube kubectl -- apply -f k8s/service.yaml
                    
                    # FIXED: Added '-deployment' to match your actual K8s resource name
                    minikube kubectl -- rollout restart deployment my-k8s-app-deployment
                    '''
                }
            }
        }
    }
}
