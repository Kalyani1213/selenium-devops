pipeline {
    agent any

    stages {
        stage('Checkout from GitHub') {
            steps {
                // Updated to YOUR repository
                git branch: 'main', 
                    url: 'https://github.com/Kalyani1213/selenium-devops.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                // Move into the specific folder to run npm
                dir('node-k8s-app-selinium') {
                    sh 'npm install'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('node-k8s-app-selinium') {
                    sh "docker build -t kalyani46/my-k8s-app:latest ."
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                // This 'docker-hub-creds' MUST match the ID in Jenkins Credentials
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', 
                                 passwordVariable: 'DOCKER_PASSWORD', 
                                 usernameVariable: 'DOCKER_USERNAME')]) {
                    
                    sh "echo ${DOCKER_PASSWORD} | docker login -u ${DOCKER_USERNAME} --password-stdin"
                    sh 'docker push kalyani46/my-k8s-app:latest'
                }
            }
        }

        stage('Start Minikube') {
            steps {
                sh '''
                if ! minikube status | grep -q "apiserver: Running"; then
                    echo "Minikube is not running. Starting now..."
                    minikube start --driver=docker
                fi
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                dir('node-k8s-app-selinium') {
                    sh '''
                    minikube kubectl -- apply -f k8s/deployment.yaml
                    minikube kubectl -- apply -f k8s/service.yaml
                    '''
                }
            }
        }
    }
}
